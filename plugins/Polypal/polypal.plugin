[Script]
http-response ^https?:\/\/api-jp\.timekettle\.co\/livetranslator\/app\/benefit\/user_plan\/current$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Polypal/polypal.js, requires-body=true, timeout=10, tag=Polypal 订阅计划

http-response ^https?:\/\/api-jp\.timekettle\.co\/livetranslator\/app\/user\/duration\/remain$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Polypal/polypal.js, requires-body=true, timeout=10, tag=Polypal 剩余时长

http-response ^https?:\/\/api-jp\.timekettle\.co\/polypal-ai\/app\/image\/benefit$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Polypal/polypal.js, requires-body=true, timeout=10, tag=Polypal 图片翻译

http-response ^https?:\/\/api-jp\.timekettle\.co\/livetranslator\/app\/document\/si\/recording\/storage$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/Polypal/polypal.js, requires-body=true, timeout=10, tag=Polypal 存储空间

[MITM]
hostname = %APPEND% api-jp.timekettle.co
