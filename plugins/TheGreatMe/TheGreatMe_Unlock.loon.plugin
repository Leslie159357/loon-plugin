#!logo=https://raw.githubusercontent.com/tgm-crack/main/logo.png
#!date=2025-01-01
#!tag=premium,unlock,thegreatme

[General]
skip_proxy = *.revenuecat.com, *.rc-backend.com

[MITM]
hostname = *.revenuecat.com, *.rc-backend.com, api-paywalls.revenuecat.com, api-diagnostics.revenuecat.com
skip_validation = true

[Script]
http-response ^https:\/\/api\.revenuecat\.com\/v1\/(subscribers|offerings|product_entitlement_mapping) requires-body = true, script-path = https://raw.githubusercontent.com/tgm-crack/TGM-Unlock/main/tgm_premium.js
http-response ^https:\/\/api-paywalls\.revenuecat\.com\/ requires-body = true, script-path = https://raw.githubusercontent.com/tgm-crack/TGM-Unlock/main/tgm_premium.js

# No URL Rewrite needed — script handles interception
# [URL Rewrite]
