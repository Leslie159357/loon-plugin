[Script]
http-response ^https?://yinke\.jinguizi07\.cn/api/auth/apple-login script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/InkerSpeak/InkerSpeak.js, requires-body=true, tag=InkerSpeak_Login
http-response ^https?://yinke\.jinguizi07\.cn/api/user/user-info script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/InkerSpeak/InkerSpeak.js, requires-body=true, tag=InkerSpeak_UserInfo
http-response ^https?://yinke\.jinguizi07\.cn/api/story-series/ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/InkerSpeak/InkerSpeak.js, requires-body=true, tag=InkerSpeak_Story
http-response ^https?://yinke\.jinguizi07\.cn/api/distribution/summary script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/InkerSpeak/InkerSpeak.js, requires-body=true, tag=InkerSpeak_Summary
http-response ^https?://yinke\.jinguizi07\.cn/api/distribution/exchange/membership script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/InkerSpeak/InkerSpeak.js, requires-body=true, tag=InkerSpeak_Exchange
[MITM]
hostname = %APPEND% yinke.jinguizi07.cn
