[Script]
http-response ^https?://pool\.elsanow\.io/entitlement/api/v1/user/entitlements\? script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-Entitlements

http-response ^https?://pool\.elsanow\.io/entitlement/api/v1/user/entitlement/elsa_speak\. script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-SingleEntitlement

http-response ^https?://pool\.elsanow\.io/entitlement/api/v1/user/operator/play_lesson script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-PlayLesson

http-response ^https?://pool\.elsanow\.io/product-catalog/v1/eligible/upgrade-to-premium script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-ProductCatalog

http-response ^https?://pool\.elsanow\.io/user-segmentation/limitation/v1/segments/lesson_limit_baseline/reset script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-LessonLimit

http-response ^https?://pool\.elsanow\.io/user/api/v1/account$ script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-UserAccount

http-response ^https?://pool\.elsanow\.io//sl-api/api/users/me/subscriptions script-path=https://raw.githubusercontent.com/Leslie159357/Loon-Plugins/main/plugins/ELSA-Speak/elsa.js, requires-body=true, timeout=10, tag=ELSA-Subscription

[Mitm]
hostname = pool.elsanow.io
